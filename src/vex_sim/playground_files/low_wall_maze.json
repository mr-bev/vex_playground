    {"start": [3000, 3000], "end": [0, 3000], "height": "tall"},
    {"start": [0, 3000], "end": [0, 0], "height": "tall"},

    {"start": [800, 0], "end": [800, 1500], "height": "low"},
    {"start": [800, 1500], "end": [1800, 1500], "height": "low"},
    {"start": [1800, 1500], "end": [1800, 600], "height": "low"},
    {"start": [1800, 600], "end": [3000, 600], "height": "low"},
